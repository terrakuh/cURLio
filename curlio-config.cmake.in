@PACKAGE_INIT@

set(CURLIO_VERSION @PROJECT_VERSION@)

include(CMakeFindDependencyMacro)
find_dependency(CURL 7.21 REQUIRED)
find_dependency(Threads REQUIRED)

if(NOT @CURLIO_USE_STANDALONE_ASIO@)
	find_dependency(Boost 1.78 REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/curlio-targets.cmake")

check_required_components(curlio)

include(FindPackageMessage)
find_package_message(curlio "Found cURLio: ${CURLIO_VERSION}" "[${CMAKE_CURRENT_LIST_DIR}]")
